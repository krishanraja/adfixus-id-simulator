# Meeting Booking URL
# Update this URL to point to your meeting booking system
VITE_MEETING_BOOKING_URL=https://outlook.office.com/book/SalesTeambooking@adfixus.com

# Optional: company name shown in the UI
# VITE_COMPANY_NAME=AdFixus

# Optional: Brandfetch Logo CDN client id.
# When set, the domain-entry step shows the visitor's real brand logo (rendered
# directly by the browser). Without it, the tool falls back to public favicon
# services - it stays fully client-side either way. This id is PUBLIC (it only
# unlocks browser-rendered logo URLs); never put a secret Brandfetch API key here.
# VITE_BRANDFETCH_CLIENT_ID=
